{
  "family": "n8n-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/n8nEcsExecutionRole",
  "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/n8nTaskRole",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "ephemeralStorage": {
    "sizeInGiB": 30
  },
  "containerDefinitions": [
    {
      "name": "n8n-management",
      "image": "docker.n8n.io/n8nio/n8n:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "n8n-ui",
          "containerPort": 5678,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "N8N_HOST", "value": "${N8N_HOST}" },
        { "name": "N8N_PROTOCOL", "value": "https" },
        { "name": "N8N_PORT", "value": "5678" },
        { "name": "N8N_EDITOR_BASE_URL", "value": "${N8N_EDITOR_BASE_URL}" },
        { "name": "WEBHOOK_URL", "value": "${WEBHOOK_URL}" },
        { "name": "DB_TYPE", "value": "postgresdb" },
        { "name": "DB_POSTGRESDB_HOST", "value": "${DB_POSTGRESDB_HOST}" },
        { "name": "DB_POSTGRESDB_PORT", "value": "5432" },
        { "name": "DB_POSTGRESDB_DATABASE", "value": "n8n" },
        { "name": "DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED", "value": "true" },
        { "name": "N8N_SECURE_COOKIE", "value": "true" },
        { "name": "N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS", "value": "true" },
        { "name": "N8N_DIAGNOSTICS_ENABLED", "value": "false" },
        { "name": "N8N_PERSONALIZATION_ENABLED", "value": "false" },
        { "name": "N8N_HIRING_BANNER_ENABLED", "value": "false" },
        { "name": "N8N_PAYLOAD_SIZE_MAX", "value": "16" },
        { "name": "GENERIC_TIMEZONE", "value": "UTC" },
        { "name": "NODE_FUNCTION_ALLOW_EXTERNAL", "value": "*" }
      ],
      "secrets": [
        {
          "name": "DB_POSTGRESDB_USER",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_DB_SECRET_NAME}:username::"
        },
        {
          "name": "DB_POSTGRESDB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_DB_SECRET_NAME}:password::"
        },
        {
          "name": "N8N_ENCRYPTION_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_APP_SECRET_NAME}:encryptionKey::"
        },
        {
          "name": "N8N_BASIC_AUTH_ACTIVE",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_APP_SECRET_NAME}:basicAuthActive::"
        },
        {
          "name": "N8N_BASIC_AUTH_USER",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_APP_SECRET_NAME}:basicAuthUser::"
        },
        {
          "name": "N8N_BASIC_AUTH_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_APP_SECRET_NAME}:basicAuthPassword::"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:5678/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 40
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/n8n-management",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "readonlyRootFilesystem": false
    },
    {
      "name": "n8n-webhook",
      "image": "docker.n8n.io/n8nio/n8n:latest",
      "essential": true,
      "command": ["n8n", "webhook"],
      "portMappings": [
        {
          "name": "n8n-webhook",
          "containerPort": 5678,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "N8N_HOST", "value": "${N8N_HOST}" },
        { "name": "N8N_PROTOCOL", "value": "https" },
        { "name": "N8N_PORT", "value": "5678" },
        { "name": "DB_TYPE", "value": "postgresdb" },
        { "name": "DB_POSTGRESDB_HOST", "value": "${DB_POSTGRESDB_HOST}" },
        { "name": "DB_POSTGRESDB_PORT", "value": "5432" },
        { "name": "DB_POSTGRESDB_DATABASE", "value": "n8n" },
        { "name": "DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED", "value": "true" },
        { "name": "N8N_SECURE_COOKIE", "value": "true" },
        { "name": "N8N_DIAGNOSTICS_ENABLED", "value": "false" },
        { "name": "N8N_PERSONALIZATION_ENABLED", "value": "false" },
        { "name": "GENERIC_TIMEZONE", "value": "UTC" }
      ],
      "secrets": [
        {
          "name": "DB_POSTGRESDB_USER",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_DB_SECRET_NAME}:username::"
        },
        {
          "name": "DB_POSTGRESDB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_DB_SECRET_NAME}:password::"
        },
        {
          "name": "N8N_ENCRYPTION_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${N8N_APP_SECRET_NAME}:encryptionKey::"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:5678/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 40
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/n8n-webhook",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
